# Source local pyshell helper (update the path if you move the repo)
if [ -f "$HOME/pyshell/dotfiles/pyshell.zsh" ]; then
  source "$HOME/pyshell/dotfiles/pyshell.zsh"
fi

# Example aliases and safe settings (REMOVE any secrets before committing)
export EDITOR=vim
alias ll='ls -la'
